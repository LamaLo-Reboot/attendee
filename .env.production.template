# =============================================================================
# Attendee — Production Environment Variables
# Copy this file to .env.production and fill in the actual values.
# =============================================================================

# --- Django ---
DJANGO_SETTINGS_MODULE=attendee.settings.production
DJANGO_SECRET_KEY=<python3 -c "import secrets; print(secrets.token_urlsafe(50))">
CREDENTIALS_ENCRYPTION_KEY=<python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())">

# --- Database ---
# POSTGRES_PASSWORD is also used by the postgres container in prod.docker-compose.yaml.
POSTGRES_PASSWORD=<generate-a-strong-password>
DATABASE_URL=postgresql://attendee_prod:<same-POSTGRES_PASSWORD>@localhost:5432/attendee_prod
POSTGRES_SSL_REQUIRE=false

# --- Redis ---
REDIS_URL=redis://localhost:6379/5

# --- Site ---
SITE_DOMAIN=attendee.example.com
ALLOWED_HOSTS=attendee.example.com

# --- Scaleway Object Storage (S3-compatible) ---
AWS_ENDPOINT_URL=https://s3.fr-par.scw.cloud
AWS_ACCESS_KEY_ID=<scaleway-access-key>
AWS_SECRET_ACCESS_KEY=<scaleway-secret-key>
AWS_DEFAULT_REGION=fr-par
AWS_RECORDING_STORAGE_BUCKET_NAME=attendee-recordings

# --- Bot Launching ---
LAUNCH_BOT_METHOD=docker-compose-multi-host
BOT_CONTAINER_IMAGE=attendee-attendee-worker-prod:latest
BOT_HOST_CODE_PATH=/opt/attendee
BOT_MEMORY_LIMIT=1g
BOT_MAX_SIMULTANEOUS_BOTS=5

# --- Auth & Security ---
DISABLE_EMAIL=true
DISABLE_SIGNUP=true
ACCOUNT_EMAIL_VERIFICATION=none

# --- OpenTelemetry (Scaleway Cockpit) ---
OTEL_EXPORTER_OTLP_ENDPOINT=https://traces.cockpit.fr-par.scw.cloud:443
OTEL_EXPORTER_OTLP_HEADERS=X-Token=<SCALEWAY_COCKPIT_TOKEN>
OTEL_SERVICE_NAME=attendee
